\name{as.data.frame.biom}
\alias{as.data.frame.biom}
\title{Coerce a biom object to a long-format tidy data frame}
\usage{
\method{as.data.frame}{biom}(x, ...)
}
\arguments{
\item{x}{A \code{\link{biom-class}} object.}
\item{...}{Ignored; present for S3 generic compatibility.}
}
\value{
A \code{\link{data.frame}} in long (tidy) format with at least
three columns: \code{feature_id}, \code{sample_id}, \code{count}.
Additional columns from \code{\link{sample_metadata}} and
\code{\link{observation_metadata}} are appended when present.
}
\description{
Returns one row per (feature, sample) pair with columns
\code{feature_id}, \code{sample_id}, and \code{count}, plus any
sample and observation metadata columns appended via a left-join.
The implementation is pure base R with no tidyverse dependency.
}
\examples{
biom_file <- system.file("extdata", "rich_dense_otu_table.biom",
                         package = "biomformat")
x <- read_biom(biom_file)
df <- as.data.frame(x)
head(df)
dim(df)
}
\seealso{
\code{\link{biom_data}}, \code{\link{as_tibble.biom}}
}
